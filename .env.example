# URL del contenedor Ollama (en Docker interno, NO expuesto al exterior)
OLLAMA_HOST=http://ollama:11434

# Modelo permitido — solo este se puede invocar
ALLOWED_MODEL=phi3:mini

# Máximo de peticiones simultáneas a Ollama (evita saturar la CPU)
MAX_CONCURRENT_REQUESTS=2

# --- CONTROL DE CUOTAS ---
# true  = sin límite (modo testing)
# false = máximo FREE_SESSION_LIMIT sesiones por usuario
UNLIMITED_SESSIONS=true
FREE_SESSION_LIMIT=2

# URL del microservicio de autenticación (para verificar cuotas en DB)
AUTH_SERVICE_URL=http://auth-service:3001

# Puerto del servicio
PORT=3003
